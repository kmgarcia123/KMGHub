# ─── BASE DE DATOS ───────────────────────────────────────
DATABASE_URL="postgresql://mughero:password@localhost:5432/mughero_db"

# ─── SERVIDOR ────────────────────────────────────────────
PORT=4000
NODE_ENV=development
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_seguro_32chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=otro_secreto_diferente_para_refresh_tokens
JWT_REFRESH_EXPIRES_IN=7d

# ─── UPLOADS ─────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ─── CLOUDINARY (imágenes en producción) ─────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── WOMPI (pagos Colombia) ──────────────────────────────
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=

# ─── CORS ────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
